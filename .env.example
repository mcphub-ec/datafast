# ─── Datafast MCP Server ───────────────────────────────────────────────────────
# Copia este archivo como .env y completa los valores REALES antes de usar.
#   cp .env.example .env && chmod 600 .env
# ─────────────────────────────────────────────────────────────────────────────

# Bearer Token entregado por Datafast al comercio.
DATAFAST_BEARER_TOKEN=

# Entity ID del comercio en Datafast.
# Nota: si tienes entityId distintos para Visa/MC y Diners, pasa entity_id
# en cada tool call desde el agente.
DATAFAST_ENTITY_ID=

# Ambiente (Opcional):
#   Producción: https://eu-prod.oppwa.com  (default)
#   Sandbox:    https://eu-test.oppwa.com
# DATAFAST_BASE_URL=https://eu-prod.oppwa.com

# (Opcional) Timeout HTTP en segundos.
# DATAFAST_HTTP_TIMEOUT=30

# Opciones: sse | http_stream
MCP_TRANSPORT_MODE=sse
MCP_PORT=8000
